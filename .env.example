# ClearLine environment — COPY to .env (Node scripts/spikes) or .dev.vars (wrangler dev).
# NEVER commit real secret values. This file holds placeholders only.

# --- TxLINE (TxODDS Oracle) ---
TXLINE_API_BASE=https://txline.txodds.com
TXLINE_DOCS_BASE=https://txline-docs.txodds.com
# Guest session JWT (POST /auth/guest/start) — 30-day lifetime
TXLINE_JWT=
# Long-lived API token (POST /api/token/activate, World Cup free tier = empty leagues)
TXLINE_API_TOKEN=

# --- Solana (devnet only) ---
SOLANA_CLUSTER=devnet
# Primary: keyed Helius devnet (Worker-friendly, no egress rate-limit). SECRET.
SOLANA_RPC_PRIMARY=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
# Backup: public devnet (failover).
SOLANA_RPC_BACKUP_1=https://api.devnet.solana.com
SOLANA_RPC_BACKUP_2=
# Dedicated devnet agent wallet: base58 secret key OR path to a keypair json.
SOLANA_AGENT_SECRET=.secrets/clearline-agent-devnet.json

# --- TxLINE on-chain (devnet) ---
TXLINE_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
